<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%- article.title %> - Tony Cletus</title>
  <meta name="description" content="<%- article.subtitle || 'Read this article by Tony Cletus.' %>" />
  <meta name="robots" content="index, follow" />
  <meta name="googlebot" content="index, follow" />

  <!-- Open Graph Protocol -->
  <meta property="og:url" content="https://tonycletus.com/articles/<%- article.slug %>.html" />
  <meta property="og:type" content="article" />
  <meta property="og:title" content="<%- article.title %> - Tony Cletus" />
  <meta property="og:description" content="<%- article.subtitle || 'Read this article by Tony Cletus.' %>" />
  <meta property="og:image"
    content="https://tonycletus.com/<%- (article.gallery_img1 || article.image || 'public/img/og-image.png').replace(/^\/+/, '') %>" />
  <meta property="og:image:alt" content="<%- article.title %>" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="Tony Cletus - Portfolio" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@iamtonycletus" />
  <meta name="twitter:creator" content="@iamtonycletus" />
  <meta name="twitter:title" content="<%- article.title %> - Tony Cletus" />
  <meta name="twitter:description" content="<%- article.subtitle || 'Read this article by Tony Cletus.' %>" />
  <meta name="twitter:image"
    content="https://tonycletus.com/<%- (article.gallery_img1 || article.image || 'public/img/og-image.png').replace(/^\/+/, '') %>" />
  <meta name="twitter:image:alt" content="<%- article.title %>" />

  <!-- Theme and Icons -->
  <meta name="theme-color" content="#f0f2a1" />
  <meta name="msapplication-TileColor" content="#f0f2a1" />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/public/img/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/public/img/favicon.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/public/img/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/public/img/favicon.png" />
  <link rel="shortcut icon" href="/public/img/favicon.ico" />

  <!-- Preconnect for Performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://unpkg.com" crossorigin>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- PWA -->
  <link rel="manifest" href="/public/manifest.json">
</head>

<body>
  <!-- Progress Bar -->
  <div class="progress-container">
    <div class="progress-bar" id="progress-bar"></div>
    <div class="progress-text" id="progress-text">0%</div>
  </div>

  <!-- Custom Toast Container -->
  <div id="toast-container" class="toast-container"></div>

  <!-- Main Content -->
  <div class="app-container">
    <div class="decorative-line"></div>

    <main class="main-content">
      <!-- Header -->
      <header class="header">
        <div class="header-brand">
          <a href="/index.html" class="brand-link">
            <img src="/public/img/logo.png" class="brand-logo" alt="Tony Cletus Logo" />
            <h1 class="brand-name">Tony Cletus</h1>
          </a>
        </div>

        <div class="header-actions">
          <div class="theme-switcher">
            <i class='bx bx-sun theme-icon'></i>
            <select id="theme-selector" class="theme-select" aria-label="Select theme">
              <option value="auto">Auto</option>
              <option value="dark" selected>Dark</option>
              <option value="light">Light</option>
            </select>
          </div>
        </div>
      </header>

      <hr class="divider">

      <!-- Article Header -->
      <header class="article-header" style="margin-bottom: 2rem;">
        <h1 class="article-title"
          style="font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; margin-bottom: 1.5rem; line-height: 1.2;"><%-
            article.title %></h1>
        <div class="article-meta"
          style="display: flex; align-items: center; flex-wrap: wrap; gap: 0.75rem; color: var(--text-color); opacity: 0.9; margin-bottom: 2rem; position: relative; font-size: 0.95rem; z-index: 20;">
          <img src="/public/img/logo.png" alt="Tony Cletus"
            style="width: 28px; height: 28px; border-radius: 50%; object-fit: cover; border: 1px solid var(--border-color);">
          <strong style="color: var(--hyperlink);">Tony Cletus</strong>
          <span>&middot;</span>
          <span><%- article.readTime %> min read</span>
          <span>&middot;</span>
          <span>
            <% const d=article.date ? new Date(article.date) : new Date(); const
              formattedDate=d.toLocaleDateString('en-US', { month: 'short' , day: 'numeric' , year: 'numeric' }); %>
              <%- formattedDate %>
          </span>
          <div class="share-container" style="margin-left: auto; position: relative;">
            <button id="share-toggle" class="share-btn"
              style="background:none; border:none; color:inherit; cursor:pointer; font-size: 1.5rem; display:flex; align-items:center; opacity: 0.8; transition: opacity 0.2s;">
              <i class='bx bx-share-alt'></i>
            </button>
            <div id="share-menu" class="share-menu"
              style="display: none; position: absolute; right: 0; top: 100%; margin-top: 0.5rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius); padding: 0.25rem; box-shadow: var(--shadow); z-index: 10; min-width: 160px;">
              <a href="#" id="share-twitter" class="share-option"
                style="display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.75rem; color: inherit; text-decoration: none; border-radius: 4px; transition: background 0.2s;"><i
                  class='bx bxl-twitter'></i> Twitter</a>
              <a href="#" id="share-whatsapp" class="share-option"
                style="display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.75rem; color: inherit; text-decoration: none; border-radius: 4px; transition: background 0.2s;"><i
                  class='bx bxl-whatsapp'></i> WhatsApp</a>
              <a href="#" id="share-telegram" class="share-option"
                style="display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.75rem; color: inherit; text-decoration: none; border-radius: 4px; transition: background 0.2s;"><i
                  class='bx bxl-telegram'></i> Telegram</a>
              <button id="share-copy" class="share-option"
                style="display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.75rem; color: inherit; background: none; border: none; font: inherit; cursor: pointer; width: 100%; text-align: left; border-radius: 4px; transition: background 0.2s;"><i
                  class='bx bx-copy'></i> Copy Link</button>
            </div>
          </div>
        </div>

        <% if (article.gallery_img1 || article.image) { %>
          <% const imgPath=article.gallery_img1 || article.image; %>
            <div class="article-thumbnail-container"
              style="width: 100%; margin-bottom: 3rem; border-radius: var(--radius); overflow: hidden; box-shadow: 0 0 25px rgba(240, 242, 161, 0.5), 0 0 50px rgba(240, 242, 161, 0.2); border: 2px solid rgba(240, 242, 161, 0.6); position: relative;">
              <img src="<%- imgPath.startsWith('public/') ? '/' + imgPath : imgPath %>"
                alt="<%- article.title %> Thumbnail"
                style="width: 100%; height: auto; display: block; max-height: 400px; object-fit: cover;" />
            </div>
            <% } %>
      </header>

      <section class="section article-body-section" style="font-size: 1.125rem; line-height: 1.8;">
        <div class="collection-description">
          <%- article.body %>
        </div>
      </section>

      <!-- Newsletter Section -->
      <section class="section newsletter-section">
        <div class="newsletter-container">
          <div class="newsletter-content">
            <h3 class="newsletter-title">Get Updates</h3>
            <p class="newsletter-description">Stay updated with my latest projects and insights.</p>

            <form id="newsletter-form" class="newsletter-form" name="newsletter" method="POST" data-netlify="true"
              netlify-honeypot="bot-field" novalidate>
              <input type="hidden" name="form-name" value="newsletter" />
              <p class="hidden">
                <label>
                  Don't fill this out if you're human: <input name="bot-field" />
                </label>
              </p>
              <div class="form-group">
                <input type="email" id="newsletter-email" name="email" class="form-input"
                  placeholder="Your email address" required autocomplete="email" />
                <div class="form-error" id="email-error"></div>
              </div>

              <button type="submit" class="form-button" id="submit-button">
                <span class="button-text">Subscribe</span>
                <i class="bx bx-bell button-icon"></i>
                <div class="button-loader" id="button-loader"></div>
              </button>
            </form>
          </div>
        </div>
      </section>

      <!-- Footer -->
      <footer class="footer">
        <p class="footer-text">
          Built with <span class="heart-icon"><i class="bx bx-heart"></i></span> by Tony Cletus
          &copy; <span id="current-year"></span>
        </p>
      </footer>
    </main>
  </div>

  <!-- Scripts -->
  <script src="/js/script.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Newsletter Form with Enhanced UX
      class NewsletterForm {
        constructor() {
          this.form = document.getElementById('newsletter-form');
          if (!this.form) return;
          this.emailInput = document.getElementById('newsletter-email');
          this.submitButton = document.getElementById('submit-button');
          this.buttonText = this.submitButton.querySelector('.button-text');
          this.buttonLoader = document.getElementById('button-loader');
          this.emailError = document.getElementById('email-error');

          this.initializeForm();
        }

        initializeForm() {
          this.form.addEventListener('submit', (e) => this.handleSubmit(e));
          this.emailInput.addEventListener('input', () => this.clearError());
          this.emailInput.addEventListener('blur', () => this.validateEmail());
        }

        validateEmail() {
          const email = this.emailInput.value.trim();
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

          if (!email) {
            this.showError('Email is required');
            return false;
          }

          if (!emailRegex.test(email)) {
            this.showError('Please enter a valid email address');
            return false;
          }

          return true;
        }

        showError(message) {
          this.emailError.textContent = message;
          this.emailInput.classList.add('input-error');
        }

        clearError() {
          this.emailError.textContent = '';
          this.emailInput.classList.remove('input-error');
        }

        setLoading(loading) {
          this.submitButton.disabled = loading;
          this.emailInput.disabled = loading;

          if (loading) {
            this.buttonText.textContent = 'Subscribing...';
            this.buttonLoader.style.display = 'block';
          } else {
            this.buttonText.textContent = 'Subscribe';
            this.buttonLoader.style.display = 'none';
          }
        }

        async handleSubmit(e) {
          e.preventDefault();

          if (!this.validateEmail()) {
            return;
          }

          this.setLoading(true);

          try {
            const formData = new FormData(this.form);

            // Check if we're in development
            const isDevelopment = window.location.hostname === 'localhost' ||
              window.location.hostname === '127.0.0.1' ||
              window.location.hostname === '';

            if (isDevelopment) {
              await new Promise(resolve => setTimeout(resolve, 1000));
              window.showToast('Successfully subscribed! Welcome to the community.', 'success');
              this.form.reset();
            } else {
              const response = await fetch('/', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams(formData).toString()
              });

              if (response.ok) {
                window.showToast('Successfully subscribed! Welcome to the community.', 'success');
                this.form.reset();
              } else {
                throw new Error(`Form submission failed: ${response.status}`);
              }
            }
          } catch (error) {
            console.error('Subscription error:', error);
            window.showToast('Failed to subscribe. Please try again.', 'error');
          } finally {
            this.setLoading(false);
          }
        }
      }

      new NewsletterForm();

      // Set current year
      const yearEl = document.getElementById('current-year');
      if (yearEl) yearEl.textContent = new Date().getFullYear();

      // Share Functionality
      const shareToggle = document.getElementById('share-toggle');
      const shareMenu = document.getElementById('share-menu');

      if (shareToggle && shareMenu) {
        shareToggle.addEventListener('click', (e) => {
          e.stopPropagation();
          shareMenu.style.display = shareMenu.style.display === 'none' ? 'block' : 'none';

          // Hover logic for options
          const options = shareMenu.querySelectorAll('.share-option');
          options.forEach(opt => {
            opt.addEventListener('mouseenter', () => opt.style.background = 'rgba(255,255,255,0.1)');
            opt.addEventListener('mouseleave', () => opt.style.background = 'transparent');
          });
        });

        document.addEventListener('click', (e) => {
          if (!shareMenu.contains(e.target) && e.target !== shareToggle) {
            shareMenu.style.display = 'none';
          }
        });

        // Set share links
        const url = encodeURIComponent(window.location.href);
        const title = encodeURIComponent(document.title);

        document.getElementById('share-twitter').href = `https://twitter.com/intent/tweet?url=${url}&text=${title}`;
        document.getElementById('share-whatsapp').href = `https://api.whatsapp.com/send?text=${title}%20${url}`;
        document.getElementById('share-telegram').href = `https://t.me/share/url?url=${url}&text=${title}`;

        document.getElementById('share-copy').addEventListener('click', () => {
          navigator.clipboard.writeText(window.location.href).then(() => {
            const btn = document.getElementById('share-copy');
            const originalText = btn.innerHTML;
            btn.innerHTML = `<i class='bx bx-check'></i> Copied!`;
            setTimeout(() => {
              btn.innerHTML = originalText;
              shareMenu.style.display = 'none';
            }, 2000);
          });
        });
      }
    });
  </script>
</body>

</html>