<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>West Sunset NFT Collection - Tony Cletus</title>
  <meta name="description"
    content="Explore the West Sunset NFT collection - a unique digital art series capturing the beauty of sunset moments on the blockchain." />
  <meta name="robots" content="index, follow" />
  <meta name="googlebot" content="index, follow" />

  <!-- Open Graph Protocol -->
  <meta property="og:url" content="https://tonycletus.com/westsunset.html" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="West Sunset NFT Collection - Tony Cletus" />
  <meta property="og:description"
    content="Explore the West Sunset NFT collection - a unique digital art series capturing the beauty of sunset moments on the blockchain." />
  <meta property="og:image" content="https://tonycletus.com/public/img/sunset-1.jpeg" />
  <meta property="og:image:alt" content="West Sunset NFT Collection" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="Tony Cletus - Portfolio" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@iamtonycletus" />
  <meta name="twitter:creator" content="@iamtonycletus" />
  <meta name="twitter:title" content="West Sunset NFT Collection - Tony Cletus" />
  <meta name="twitter:description" content="Explore the West Sunset NFT collection - a unique digital art series." />
  <meta name="twitter:image" content="https://tonycletus.com/public/img/sunset-1.jpeg" />
  <meta name="twitter:image:alt" content="West Sunset NFT Collection" />

  <!-- Theme and Icons -->
  <meta name="theme-color" content="#f0f2a1" />
  <meta name="msapplication-TileColor" content="#f0f2a1" />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/public/img/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/public/img/favicon.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/public/img/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/public/img/favicon.png" />
  <link rel="shortcut icon" href="/public/img/favicon.ico" />

  <!-- Preconnect for Performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://unpkg.com" crossorigin>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- PWA -->
  <link rel="manifest" href="/public/manifest.json">
</head>

<body>
  <!-- Progress Bar -->
  <div class="progress-container">
    <div class="progress-bar" id="progress-bar"></div>
    <div class="progress-text" id="progress-text">0%</div>
  </div>

  <!-- Custom Toast Container -->
  <div id="toast-container" class="toast-container"></div>

  <!-- Main Content -->
  <div class="app-container">
    <div class="decorative-line"></div>

    <main class="main-content">
      <!-- Header -->
      <header class="header">
        <div class="header-brand">
          <a href="/index.html" class="brand-link">
            <img src="/public/img/logo.png" class="brand-logo" alt="Tony Cletus Logo" />
            <h1 class="brand-name">Tony Cletus</h1>
          </a>
        </div>

        <div class="header-actions">
          <div class="theme-switcher">
            <i class='bx bx-sun theme-icon'></i>
            <select id="theme-selector" class="theme-select" aria-label="Select theme">
              <option value="auto">Auto</option>
              <option value="dark" selected>Dark</option>
              <option value="light">Light</option>
            </select>
          </div>
        </div>
      </header>

      <hr class="divider">

      <!-- Hero Section -->
      <section class="section hero-section">
        <div class="hero-content">
          <div class="hero-text">
            <h1 class="hero-title"><%- article.title %></h1>
            <p class="hero-subtitle"><%- article.subtitle || '' %></p>
            <div class="hero-stats">
              <div class="hero-stat">
                <span class="stat-number"><%- article.readTime %></span>
                <span class="stat-label">Min Read</span>
              </div>
            </div>
          </div>
          <% if (article.image) { %>
            <div class="hero-image">
              <img src="<%- article.image.startsWith('public/') ? article.image : '/' + article.image %>"
                alt="Article Preview" class="hero-preview" />
            </div>
            <% } %>
        </div>
      </section>

      <!-- About Collection Section -->
      <section class="section about-collection-section">
        <div class="section-header">
          <h2 class="section-title">About the Collection</h2>
          <i class='bx bx-palette section-icon'></i>
        </div>

        <div class="collection-description">
          <%- article.body %>
        </div>
      </section>

      <% if (article.gallery_img1) { %>
        <section class="section gallery-section">
          <div class="section-header">
            <h2 class="section-title">Collection Preview</h2>
            <i class='bx bx-images section-icon'></i>
          </div>

          <div class="gallery-grid">
            <div class="gallery-item">
              <img src="<%- article.gallery_img1 %>" alt="Preview Image" class="gallery-image" />
            </div>
          </div>
        </section>
        <% } %>

          <!-- Newsletter Section -->
          <section class="section newsletter-section">
            <div class="newsletter-container">
              <div class="newsletter-content">
                <h3 class="newsletter-title">Get Updates</h3>
                <p class="newsletter-description">Stay updated with my latest projects and insights.</p>

                <form id="newsletter-form" class="newsletter-form" name="newsletter" method="POST" data-netlify="true"
                  netlify-honeypot="bot-field" novalidate>
                  <input type="hidden" name="form-name" value="newsletter" />
                  <p class="hidden">
                    <label>
                      Don't fill this out if you're human: <input name="bot-field" />
                    </label>
                  </p>
                  <div class="form-group">
                    <input type="email" id="newsletter-email" name="email" class="form-input"
                      placeholder="Your email address" required autocomplete="email" />
                    <div class="form-error" id="email-error"></div>
                  </div>

                  <button type="submit" class="form-button" id="submit-button">
                    <span class="button-text">Subscribe</span>
                    <i class="bx bx-bell button-icon"></i>
                    <div class="button-loader" id="button-loader"></div>
                  </button>
                </form>
              </div>
            </div>
          </section>

          <!-- Footer -->
          <footer class="footer">
            <p class="footer-text">
              Built with <span class="heart-icon"><i class="bx bx-heart"></i></span> by Tony Cletus
              &copy; <span id="current-year"></span>
            </p>
          </footer>
    </main>
  </div>

  <!-- Scripts -->
  <script src="/js/script.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Newsletter Form with Enhanced UX
      class NewsletterForm {
        constructor() {
          this.form = document.getElementById('newsletter-form');
          if (!this.form) return;
          this.emailInput = document.getElementById('newsletter-email');
          this.submitButton = document.getElementById('submit-button');
          this.buttonText = this.submitButton.querySelector('.button-text');
          this.buttonLoader = document.getElementById('button-loader');
          this.emailError = document.getElementById('email-error');

          this.initializeForm();
        }

        initializeForm() {
          this.form.addEventListener('submit', (e) => this.handleSubmit(e));
          this.emailInput.addEventListener('input', () => this.clearError());
          this.emailInput.addEventListener('blur', () => this.validateEmail());
        }

        validateEmail() {
          const email = this.emailInput.value.trim();
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

          if (!email) {
            this.showError('Email is required');
            return false;
          }

          if (!emailRegex.test(email)) {
            this.showError('Please enter a valid email address');
            return false;
          }

          return true;
        }

        showError(message) {
          this.emailError.textContent = message;
          this.emailInput.classList.add('input-error');
        }

        clearError() {
          this.emailError.textContent = '';
          this.emailInput.classList.remove('input-error');
        }

        setLoading(loading) {
          this.submitButton.disabled = loading;
          this.emailInput.disabled = loading;

          if (loading) {
            this.buttonText.textContent = 'Subscribing...';
            this.buttonLoader.style.display = 'block';
          } else {
            this.buttonText.textContent = 'Subscribe';
            this.buttonLoader.style.display = 'none';
          }
        }

        async handleSubmit(e) {
          e.preventDefault();

          if (!this.validateEmail()) {
            return;
          }

          this.setLoading(true);

          try {
            const formData = new FormData(this.form);

            // Check if we're in development
            const isDevelopment = window.location.hostname === 'localhost' ||
              window.location.hostname === '127.0.0.1' ||
              window.location.hostname === '';

            if (isDevelopment) {
              await new Promise(resolve => setTimeout(resolve, 1000));
              window.showToast('Successfully subscribed! Welcome to the community.', 'success');
              this.form.reset();
            } else {
              const response = await fetch('/', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams(formData).toString()
              });

              if (response.ok) {
                window.showToast('Successfully subscribed! Welcome to the community.', 'success');
                this.form.reset();
              } else {
                throw new Error(`Form submission failed: ${response.status}`);
              }
            }
          } catch (error) {
            console.error('Subscription error:', error);
            window.showToast('Failed to subscribe. Please try again.', 'error');
          } finally {
            this.setLoading(false);
          }
        }
      }

      new NewsletterForm();

      // Set current year
      const yearEl = document.getElementById('current-year');
      if (yearEl) yearEl.textContent = new Date().getFullYear();
    });
  </script>
</body>

</html>