        <div class="section-header">
          <h2 class="section-title">Featured Projects</h2>
          <i class="section-icon bx bx-rocket"></i>
        </div>

        <p class="section-subtitle">Innovative solutions built for privacy, accessibility, and inclusive infrastructure.
        </p>

        <div class="projects-grid">
          <% projects.forEach(function(project) { %>
            <div
              class="project-card <% if (project.status === 'Live') { %>project-live<% } else { %>project-upcoming<% } %>">
              <div class="project-header">
                <h3 class="project-title"><%- project.title %></h3>
                <span class="project-status"><%- project.status %></span>
              </div>
              <p class="project-description"><%- project.description %></p>

              <% if (project.tags && project.tags.length> 0) { %>
                <div class="project-tech">
                  <% project.tags.forEach(function(tag) { %>
                    <span class="tech-tag"><%- tag %></span>
                    <% }); %>
                </div>
                <% } %>

                  <div class="project-links">
                    <% if (project.link_url) { %>
                      <% const isExternalProj=project.link_url.startsWith('http'); %>
                        <a href="<%- project.link_url %>" class="project-link" <%- isExternalProj
                          ? 'target="_blank" rel="noopener"' : '' %>>
                          <i class="bx <%- isExternalProj ? 'bx-link-external' : 'bx-link-alt' %>"></i>
                          <%- project.link_text || 'Visit Site' %>
                        </a>
                        <% } %>
                          <% if (project.github_url) { %>
                            <a href="<%- project.github_url %>" class="project-link" target="_blank" rel="noopener">
                              <i class="bx bxl-github"></i>
                              Source
                            </a>
                            <% } %>
                  </div>
            </div>
            <% }); %>
        </div>
      </section>

      <!-- Articles Section -->
      <section class="section articles-section">
        <div class="section-header">
          <h2 class="section-title"> Essays & Blog Posts</h2>
          <i class="section-icon bx bx-pencil"></i>
        </div>

        <div class="articles-list">
          <% if (typeof liveArticles !=='undefined' && liveArticles.length> 0) { %>
            <% liveArticles.forEach(function(article) { %>
              <article class="article-item">
                <% if (article.gallery_img1) { %>
                  <img
                    src="<%- article.gallery_img1.startsWith('public/') ? '/' + article.gallery_img1 : article.gallery_img1 %>"
                    alt="Thumbnail" class="article-thumb"
                    style="width: 24px; height: 24px; border-radius: 4px; object-fit: cover; margin-right: 0.5rem;" />
                  <% } else { %>
                    <i class="bx bx-pen article-icon"></i>
                    <% } %>
                      <a href="<%- article.is_external ? article.external_url : '/articles/' + article.slug + '.html' %>"
                        class="article-link" <% if (article.is_external) { %>target="_blank" rel="noopener"<% } %>>
                          <span class="article-title-text"><%- article.title %></span>
                          <% if (article.is_external && article.external_source) { %>
                            <span class="article-badge"><%- article.external_source %></span>
                            <% } %>
                      </a>
              </article>
              <% }); %>
                <% } %>

                  <% if (typeof upcomingArticles !=='undefined' && upcomingArticles.length> 0) { %>
                    <div class="articles-upcoming">
                      <h3 class="upcoming-title">Upcoming Articles</h3>
                      <% upcomingArticles.forEach(function(article) { %>
                        <article class="article-item article-upcoming">
                          <i class="bx bx-time article-icon"></i>
                          <span class="article-link"><%- article.title %></span>
                        </article>
                        <% }); %>
                    </div>
                    <% } %>
        </div>
  </div>
  </section>

  <!-- Newsletter Section -->
  <section class="section newsletter-section">
    <div class="newsletter-container">
      <div class="newsletter-content">
        <h3 class="newsletter-title">Get Updates</h3>
        <p class="newsletter-description">Stay updated with my latest projects and insights.</p>

        <form id="newsletter-form" class="newsletter-form" name="newsletter" method="POST" data-netlify="true"
          netlify-honeypot="bot-field" novalidate>
          <input type="hidden" name="form-name" value="newsletter" />
          <p class="hidden">
            <label>
              Don't fill this out if you're human: <input name="bot-field" />
            </label>
          </p>
          <div class="form-group">
            <input type="email" id="newsletter-email" name="email" class="form-input" placeholder="Your email address"
              required autocomplete="email" />
            <div class="form-error" id="email-error"></div>
          </div>

          <button type="submit" class="form-button" id="submit-button">
            <span class="button-text">Subscribe</span>
            <i class="bx bx-bell button-icon"></i>
            <div class="button-loader" id="button-loader"></div>
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <p class="footer-text">
      Built with <span class="heart-icon"><i class="bx bx-heart"></i></span> by Tony Cletus
      &copy; <span id="current-year"></span>
    </p>
  </footer>
  </main>
  </div>

  <!-- Scripts -->
  <script>
    // Theme Management
    function applyTheme(theme) {
      document.body.classList.remove("theme-auto", "theme-light", "theme-dark");
      document.body.classList.add(`theme-${theme}`);
      localStorage.setItem("theme", theme);
    }

    function initializeTheme() {
      const savedTheme = localStorage.getItem("theme") || "dark";
      applyTheme(savedTheme);

      const themeSelector = document.getElementById("theme-selector");
      themeSelector.value = savedTheme;

      themeSelector.addEventListener("change", function () {
        applyTheme(this.value);
        triggerHapticFeedback('theme');
      });
    }

    // Custom Toast Notification System
    class ToastManager {
      constructor() {
        this.container = document.getElementById('toast-container');
      }

      show(message, type = 'info', duration = 4000) {
        const toast = document.createElement('div');
        toast.className = `toast toast-${type}`;

        const icon = this.getIcon(type);

        toast.innerHTML = `
          <div class="toast-content">
            <i class="toast-icon ${icon}"></i>
            <span class="toast-message">${message}</span>
          </div>
          <button class="toast-close" onclick="this.parentElement.remove()">
            <i class="bx bx-x"></i>
          </button>
        `;

        this.container.appendChild(toast);

        // Add entrance animation
        setTimeout(() => toast.classList.add('toast-show'), 10);

        // Auto remove
        setTimeout(() => {
          if (toast.parentElement) {
            toast.classList.remove('toast-show');
            setTimeout(() => toast.remove(), 300);
          }
        }, duration);

        // Haptic feedback (if supported)
        triggerHapticFeedback('light');
      }

      getIcon(type) {
        const icons = {
          success: 'bx bx-check-circle',
          error: 'bx bx-error-circle',
          warning: 'bx bx-error',
          info: 'bx bx-info-circle'
        };
        return icons[type] || icons.info;
      }
    }

    // Newsletter Form with Enhanced UX
    class NewsletterForm {
      constructor() {
        this.form = document.getElementById('newsletter-form');
        this.emailInput = document.getElementById('newsletter-email');
        this.submitButton = document.getElementById('submit-button');
        this.buttonText = this.submitButton.querySelector('.button-text');
        this.buttonLoader = document.getElementById('button-loader');
        this.emailError = document.getElementById('email-error');
        this.toast = new ToastManager();

        this.initializeForm();
      }

      initializeForm() {
        this.form.addEventListener('submit', (e) => this.handleSubmit(e));
        this.emailInput.addEventListener('input', () => this.clearError());
        this.emailInput.addEventListener('blur', () => this.validateEmail());
      }

      validateEmail() {
        const email = this.emailInput.value.trim();
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        if (!email) {
          this.showError('Email is required');
          return false;
        }

        if (!emailRegex.test(email)) {
          this.showError('Please enter a valid email address');
          return false;
        }

        return true;
      }

      showError(message) {
        this.emailError.textContent = message;
        this.emailInput.classList.add('input-error');
      }

      clearError() {
        this.emailError.textContent = '';
        this.emailInput.classList.remove('input-error');
      }

      setLoading(loading) {
        this.submitButton.disabled = loading;
        this.emailInput.disabled = loading;

        if (loading) {
          this.buttonText.textContent = 'Subscribing...';
          this.buttonLoader.style.display = 'block';
        } else {
          this.buttonText.textContent = 'Subscribe';
          this.buttonLoader.style.display = 'none';
        }
      }

      async handleSubmit(e) {
        e.preventDefault();

        if (!this.validateEmail()) {
          return;
        }

        this.setLoading(true);

        try {
          const formData = new FormData(this.form);

          // Check if we're in development (localhost) or production
          const isDevelopment = window.location.hostname === 'localhost' ||
            window.location.hostname === '127.0.0.1' ||
            window.location.hostname === '';

          if (isDevelopment) {
            // Simulate form submission in development
            console.log('Development mode: Simulating form submission');
            await new Promise(resolve => setTimeout(resolve, 1000)); // Simulate network delay

            // Log the form data for development
            const email = formData.get('email');
            console.log('Form data that would be submitted:', { email });

            this.toast.show('Successfully subscribed! Welcome to the community.', 'success');
            triggerHapticFeedback('success');
            this.form.reset();
          } else {
            // Submit to Netlify in production
            const response = await fetch('/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: new URLSearchParams(formData).toString()
            });

            if (response.ok) {
              this.toast.show('Successfully subscribed! Welcome to the community.', 'success');
              triggerHapticFeedback('success');
              this.form.reset();
            } else {
              throw new Error(`Form submission failed: ${response.status}`);
            }
          }

        } catch (error) {
          console.error('Subscription error:', error);
          this.toast.show('Failed to subscribe. Please try again.', 'error');
          triggerHapticFeedback('error');
        } finally {
          this.setLoading(false);
        }
      }
    }

    // Haptic Feedback Utility
    function triggerHapticFeedback(intensity = 'light') {
      if (navigator.vibrate) {
        const patterns = {
          light: [10],
          medium: [20],
          strong: [30],
          success: [50, 50, 50],
          error: [100, 50, 100],
          theme: [15, 15, 15]
        };
        navigator.vibrate(patterns[intensity] || patterns.light);
      }
    }

    // Initialize everything when DOM is loaded
    document.addEventListener('DOMContentLoaded', () => {
      // Initialize theme
      initializeTheme();

      // Initialize newsletter form
      new NewsletterForm();

      // Set current year
      document.getElementById('current-year').textContent = new Date().getFullYear();

      // Check for success parameter from form submission
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('subscribed') === 'true') {
        const toast = new ToastManager();
        toast.show('Successfully subscribed! Welcome to the community.', 'success');
        // Clean up the URL
        window.history.replaceState({}, document.title, window.location.pathname);
      }

      // Show development mode indicator
      const isDevelopment = window.location.hostname === 'localhost' ||
        window.location.hostname === '127.0.0.1' ||
        window.location.hostname === '';
      if (isDevelopment) {
        const devBanner = document.createElement('div');
        devBanner.style.cssText = `
          position: fixed;
          top: 0;
          left: 0;
          right: 0;
          background: #f59e0b;
          color: white;
          text-align: center;
          padding: 8px;
          font-size: 12px;
          font-weight: 600;
          z-index: 10001;
          font-family: 'Syne', sans-serif;
        `;
        devBanner.textContent = '🛠️ Development Mode - Form submissions are simulated';
        document.body.appendChild(devBanner);
      }

      // Add haptic feedback to interactive elements
      const hapticElements = document.querySelectorAll(`
        .form-button, .cv-button, .hero-button, .download-button, 
        .project-link, .social-link, .theme-select, .tool-link,
        .article-link, .skill-card, .experience-item, .ai-card,
        .project-card, .award-card, .education-item
      `);

      hapticElements.forEach(element => {
        element.addEventListener('click', () => {
          triggerHapticFeedback('light');
        });

        element.addEventListener('mouseenter', () => {
          triggerHapticFeedback('light');
        });
      });

      // Special haptic feedback for theme switching
      const themeSelector = document.getElementById('theme-selector');
      if (themeSelector) {
        themeSelector.addEventListener('change', () => {
          triggerHapticFeedback('theme');
        });
      }

      // Add smooth scrolling for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          }
        });
      });

      // Add intersection observer for animations
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-in');
          }
        });
      }, observerOptions);

      // Observe sections for animation
      document.querySelectorAll('.section').forEach(section => {
        observer.observe(section);
      });

      // Progress Bar Functionality
      const progressBar = document.getElementById('progress-bar');
      const progressText = document.getElementById('progress-text');
      let progressTimeout;

      function updateProgress() {
        const scrollTop = window.pageYOffset;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrollPercent = (scrollTop / docHeight) * 100;

        progressBar.style.width = scrollPercent + '%';
        progressText.textContent = Math.round(scrollPercent) + '%';

        // Show progress text when scrolling
        progressText.classList.add('show');
        clearTimeout(progressTimeout);

        progressTimeout = setTimeout(() => {
          progressText.classList.remove('show');
        }, 2000);
      }

      // Throttle scroll events for performance
      let ticking = false;
      function requestTick() {
        if (!ticking) {
          requestAnimationFrame(updateProgress);
          ticking = true;
        }
      }

      window.addEventListener('scroll', () => {
        ticking = false;
        requestTick();
      });

      // Initial progress update
      updateProgress();
    });

    // Service Worker Registration
    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.register('public/sw.js')
        .then(registration => {
          console.log('Service Worker registered successfully:', registration);
        })
        .catch(error => {
          console.log('Service Worker registration failed:', error);
        });
    }
  </script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on('init', user => {
        if (!user) {
          window.netlifyIdentity.on('login', () => {
            document.location.href = '/admin/';
          });
        }
      });
    }
  </script>
</body>

</html>